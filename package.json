{
  "name": "rosette",
  "version": "1.0.0",
  "description": "Electric Socket Planner - Baltic Construction Standards",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,json}\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://samoletovs@github.com/samoletovs/rosette.git"
  },
  "keywords": [],
